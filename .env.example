# Copy to .env to override defaults. All settings are optional.

# Public base URL. Set this in production: canonical, Open Graph and sitemap URLs
# are built from it. Left empty, they fall back to the request host.
AIAGG_PUBLIC_URL=https://ainews.codenlearn.in

# Ollama (local LLM — no paid API)
AIAGG_OLLAMA_HOST=http://localhost:11434
AIAGG_OLLAMA_MODEL=qwen2.5:7b
AIAGG_OLLAMA_EMBED_MODEL=nomic-embed-text

# Scheduling (seconds / hour)
AIAGG_FETCH_INTERVAL=43200   # refresh feeds every 12 hours
AIAGG_ENRICH_INTERVAL=60
AIAGG_ENRICH_BATCH=8
AIAGG_DIGEST_HOUR=7

# Clustering
AIAGG_CLUSTER_WINDOW_DAYS=7
AIAGG_CLUSTER_THRESHOLD=0.55

# Hidden visitor-analytics page (not linked in the UI).
# Reachable at AIAGG_ANALYTICS_PATH; if a token is set it must be passed as ?key=<token>.
AIAGG_ANALYTICS_PATH=/_insights
AIAGG_ANALYTICS_TOKEN=xyz75063

# Comma-separated IPs to exclude from all visit/engagement tracking and reporting
# (e.g. your own IP, so your own visits don't skew the numbers). The insights
# page shows "the IP the server sees you as" — copy it in here.
AIAGG_ANALYTICS_EXCLUDE_IPS=
